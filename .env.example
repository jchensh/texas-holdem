# 服务端口
PORT=3000

# 运行模式（development | production）
NODE_ENV=development

# Session 签名密钥 —— 生产环境必须设置一个长随机字符串
# 生成：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# 管理后台登录密码 —— 生产环境务必设置（默认 admin888 仅供本地开发）
ADMIN_PASSWORD=

# SQLite 数据库路径（可选，默认 data/poker.db）
# DB_PATH=
